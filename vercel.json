{
    "version": 2,
    "builds": [
        { "src": "api/index.php", "use": "vercel-php@0.6.2" },
        { "src": "public/**", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/images/(.*)", "dest": "/public/images/$1" },
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true", 
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr",
        "VIEW_COMPILED_PATH": "/tmp"
    }
}